{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BASE_API_URL": "https://saavn.sumit.co"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {}
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BASE_API_URL": "https://saavn.sumit.co"
      }
    }
  },
  "submit": {
    "production": {}
  }
}